{
  "name": "@overlay/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./password": {
      "types": "./dist/password.d.ts",
      "default": "./dist/password.js"
    },
    "./tipster-profile": {
      "types": "./src/tipster-profile.ts",
      "default": "./src/tipster-profile.ts"
    },
    "./markdown": {
      "types": "./src/markdown.ts",
      "default": "./src/markdown.ts"
    },
    "./subscriptions": {
      "types": "./src/subscriptions.ts",
      "default": "./src/subscriptions.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-strip-types --test src/*.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
