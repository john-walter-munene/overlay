// Overlay Bets — Prisma schema (v1)
// See docs/ARCHITECTURE.md §4 for the data model and integrity rules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  tipster
  admin
}

enum PickStatus {
  pending
  won
  lost
  void
}

enum SubscriptionStatus {
  active
  past_due
  canceled
}

enum PayoutStatus {
  pending
  paid
  failed
}

enum ArticleStatus {
  draft
  pending
  published
  archived
}

/// Delivery cadence for a user's notifications (OB-033).
/// `instant` fans out per pick; `daily` batches picks into one digest email.
enum NotificationFrequency {
  instant
  daily
}

/// Subscription billing cadence a tipster offers (OB-020).
enum BillingInterval {
  weekly
  monthly
}

model User {
  id             String         @id @default(cuid())
  role           Role           @default(user)
  email          String         @unique
  // User-chosen public handle (unique, lowercased). Optional until set.
  username       String?        @unique
  // Supabase owns authentication; passwordHash is legacy/optional.
  passwordHash   String?
  supabaseUserId String?        @unique
  createdAt      DateTime       @default(now())

  tipster       Tipster?
  subscriptions Subscription[]
  articles      Article[]
  notificationPreference NotificationPreference?
}

model Tipster {
  userId                 String   @id
  user                   User     @relation(fields: [userId], references: [id])
  // Public identity (OB-020): shown on the profile / marketplace card.
  displayName            String?
  country                String?
  // Preferred direct-contact channel captured at onboarding: one of
  // `phone` | `telegram` | `whatsapp`, with the handle/number in contactValue.
  contactMethod          String?
  contactValue           String?
  bio                    String?
  sports                 String[]
  subscriptionPriceCents Int      @default(0)
  // Billing cadence the subscription price is charged on (OB-020).
  billingInterval        BillingInterval @default(monthly)
  stripeAccountId        String?
  // Payout destination (OB-06x): which rail a tipster is paid out on and its
  // details. `payoutMethod` is one of `stripe` | `crypto` | `mobile_money`;
  // Stripe uses stripeAccountId, crypto the wallet fields, mobile money the
  // phone + network fields.
  payoutMethod           String?
  payoutWalletAddress    String?
  payoutWalletChain      String?
  payoutMobileNumber     String?
  payoutMobileNetwork    String?
  // Onboarding wizard (OB-020): Stripe Connect onboarding + identity
  // verification progress. Publishing is gated until every required step
  // (profile, sports, bio, pricing, Stripe) is complete; verification is an
  // optional trust step that unlocks the "verified" badge.
  stripeOnboarded        Boolean  @default(false)
  identityVerified       Boolean  @default(false)
  // Social / "digital identity" handles surfaced on the verified profile.
  socialX                String?
  socialInstagram        String?
  socialTelegram         String?
  // Uploaded official document (ID / passport / driver licence) backing the
  // verification step. Path is storage-relative; name is the original filename.
  identityDocPath        String?
  identityDocName        String?
  identityDocSubmittedAt DateTime?
  status                 String   @default("active")
  createdAt              DateTime @default(now())

  picks         Pick[]
  subscriptions Subscription[]
  stats         TipsterStats?
  payouts       Payout[]
}

model Event {
  id                String    @id @default(cuid())
  vendorEventId     String    @unique
  sport             String
  league            String?
  home              String
  away              String
  startTime         DateTime
  status            String    @default("scheduled")
  closingCapturedAt DateTime?

  picks Pick[]

  @@index([startTime])
}

/// Append-only. Core fields are immutable after `lockedAt`.
/// Only the settlement worker writes settlement fields (status/result/closingOdds/clv/settledAt).
model Pick {
  id         String  @id @default(cuid())
  tipsterId  String
  tipster    Tipster @relation(fields: [tipsterId], references: [userId])
  eventId    String
  event      Event   @relation(fields: [eventId], references: [id])

  market     String
  selection  String
  oddsAtPick Float
  stakeUnits Float   @default(1)
  // Optional tipster-authored context / reasoning, captured at lock time.
  // Not part of the integrity hash — it's commentary, not the wager itself.
  note       String?

  // Integrity fields (set at lock time, never mutated)
  hash     String
  nonce    String
  lockedAt DateTime @default(now())

  // Settlement fields (worker-only writes)
  status      PickStatus @default(pending)
  closingOdds Float?
  clv         Float?
  result      String?
  settledAt   DateTime?

  @@index([tipsterId, status])
  @@index([eventId, status])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id])
  tipsterId            String
  tipster              Tipster            @relation(fields: [tipsterId], references: [userId])
  // Which payment provider settles this subscription (stripe, crypto, momo…).
  provider             String             @default("stripe")
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(active)
  currentPeriodEnd     DateTime?

  @@unique([userId, tipsterId])
}

/// Materialized stats, recomputed by the stats worker after each settlement batch.
model TipsterStats {
  tipsterId     String   @id
  tipster       Tipster  @relation(fields: [tipsterId], references: [userId])
  roi           Float    @default(0)
  yield         Float    @default(0)
  clvAvg        Float    @default(0)
  winRate       Float    @default(0)
  sampleSize    Int      @default(0)
  maxDrawdown   Float    @default(0)
  currentStreak Int      @default(0)
  updatedAt     DateTime @updatedAt
}

model Payout {
  id               String       @id @default(cuid())
  tipsterId        String
  tipster          Tipster      @relation(fields: [tipsterId], references: [userId])
  amountCents      Int
  period           String
  status           PayoutStatus @default(pending)
  stripeTransferId String?
  createdAt        DateTime     @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  entity    String
  entityId  String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

/// SEO content surface (blog / strategy guides). Drives organic traffic.
/// Slug is immutable-by-convention once published so external links don't rot.
model Article {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  excerpt         String
  body            String // markdown
  coverImage      String?
  tags            String[]
  status          ArticleStatus @default(draft)
  readingMinutes  Int           @default(1)

  // SEO overrides (fall back to title/excerpt when null)
  seoTitle        String?
  seoDescription  String?
  canonicalUrl    String?

  authorId        String
  author          User          @relation(fields: [authorId], references: [id])

  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([tags])
}

/// Per-user notification preferences (OB-033): channel opt-in (email/push, or
/// both off = fully unsubscribed) and cadence (instant vs daily digest). The
/// `unsubscribeToken` backs CAN-SPAM one-click unsubscribe links in emails.
model NotificationPreference {
  userId           String                @id
  user             User                  @relation(fields: [userId], references: [id])
  emailEnabled     Boolean               @default(true)
  pushEnabled      Boolean               @default(true)
  frequency        NotificationFrequency @default(instant)
  unsubscribeToken String                @unique
  updatedAt        DateTime              @updatedAt
}
