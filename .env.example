# ─── Core ───────────────────────────────────────────────
NODE_ENV=development

# ─── Database / cache ───────────────────────────────────
DATABASE_URL=postgresql://overlay:overlay@localhost:5432/overlay?schema=public
REDIS_URL=redis://localhost:6379

# ─── API ────────────────────────────────────────────────
API_PORT=4000
JWT_SECRET=change-me-in-prod

# ─── Web ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Integrity ──────────────────────────────────────────
# Server-side pepper mixed into pick hashes (rotate carefully)
PICK_HASH_PEPPER=change-me

# ─── Sports data vendor (see docs/VENDOR-SPIKE.md) ──────
SPORTS_API_PROVIDER=the-odds-api
SPORTS_API_KEY=

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_RATE=0.25

# ─── Email ──────────────────────────────────────────────
RESEND_API_KEY=

# ─── Web Push (VAPID) ───────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
