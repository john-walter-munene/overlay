# ─── Core ───────────────────────────────────────────────
NODE_ENV=development

# ─── Observability / logging (OB-091) ───────────────────
# Structured JSON logs go to stdout (info/debug/verbose) and stderr (warn/error),
# each enriched with the request/job correlation id (see docs/OBSERVABILITY.md).
# Minimum level to emit; enables that level and everything more severe. One of:
# error | warn | info (alias: log) | debug | verbose. Defaults to "info".
LOG_LEVEL=info

# ─── Database / cache ───────────────────────────────────
DATABASE_URL=postgresql://overlay:overlay@localhost:5432/overlay?schema=public
REDIS_URL=redis://localhost:6379

# ─── API ────────────────────────────────────────────────
API_PORT=4000
# Placeholder ONLY. Production refuses to boot with a default/weak value.
# Generate a strong secret (>=32 chars): `openssl rand -hex 32`.
# Rotation guidance: docs/RUNBOOK-SECRETS.md
JWT_SECRET=change-me-in-prod
WORKER_INTERVAL_MS=60000
# Worker execution mode: "interval" (in-process, no infra) or "queue" (BullMQ/Redis)
WORKER_MODE=interval
# Port the "queue"-mode worker serves /metrics on for Prometheus (0 disables)
WORKER_METRICS_PORT=9100

# ─── Rate limiting / abuse protection (OB-080) ──────────
# Shared window (ms) all buckets are measured over.
THROTTLE_TTL_MS=60000
# Global ceiling per IP for ordinary browsing.
THROTTLE_LIMIT=120
# Stricter budget for auth routes (credential-stuffing protection).
THROTTLE_AUTH_LIMIT=20
# Stricter budget for state-changing writes (pick submission, checkout, payouts).
THROTTLE_WRITE_LIMIT=30

# ─── Web ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# Public site origin — used for canonical URLs, sitemap, and OpenGraph
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Auth: Supabase (OB-145) ────────────────────────────
# API verifies Supabase access tokens via the project's JWKS — no secret needed.
SUPABASE_URL=https://your-project.supabase.co
# Web (browser) client — publishable anon key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Storage: Supabase (OB-020) ─────────────────────────
# Server-only service role key for uploading private identity documents.
# When unset, uploads fall back to the local UPLOAD_DIR (dev only).
SUPABASE_SERVICE_ROLE_KEY=
# Private bucket identity documents are stored in.
SUPABASE_STORAGE_BUCKET=identity-documents
# Local-dev fallback directory used when SUPABASE_SERVICE_ROLE_KEY is unset.
UPLOAD_DIR=./uploads

# ─── Integrity ──────────────────────────────────────────
# Server-side pepper mixed into pick hashes. Placeholder ONLY — production
# refuses to boot with a default/weak value. Generate: `openssl rand -hex 32`.
# Rotating the pepper breaks re-verification of existing pick hashes; read the
# rotation runbook BEFORE changing it: docs/RUNBOOK-SECRETS.md
PICK_HASH_PEPPER=change-me
# Picks close this many minutes before kickoff (server clock is authoritative).
PICK_CUTOFF_MINUTES=10
# Clock-skew tolerance (seconds) granted in the tipster's favour at the cutoff.
PICK_CLOCK_SKEW_SECONDS=60
# Rising-tipster graduation threshold (OB-153). A provisional "rising" tipster's
# tips are free/public until they meet BOTH floors, at which point they're
# surfaced for admin review to assign the verified tag. Derived from verified
# settled picks; graduation never auto-enables billing.
TIPSTER_GRADUATION_MIN_WIN_RATE_PCT=60
TIPSTER_GRADUATION_MIN_SETTLED_BETS=20

# ─── Sports data vendor (see docs/VENDOR-SPIKE.md) ──────
# Use "mock" for a keyless local run; switch to a real vendor once you have a key.
SPORTS_API_PROVIDER=mock
SPORTS_API_KEY=
# Comma-separated vendor sport keys the scheduled ingestion job pulls
# (e.g. The Odds API: "soccer_epl,basketball_nba"). Unset = ingestion job off.
INGEST_SPORTS=
# How often the worker ingests fixtures (default 15 min).
INGEST_INTERVAL_MS=900000

# ─── Stripe ─────────────────────────────────────────────
PAYMENTS_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_RATE=0.25

# ─── Crypto stablecoin provider — Coinbase Commerce (OB-06x) ─
# USDC/USDT via Coinbase Commerce hosted charges. Unset = dev fallback
# (success-page webhook trigger, no real charge). Pay-per-period.
# Webhook URL: {PUBLIC_API_URL}/api/subscriptions/webhook/crypto
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# ─── Mobile money provider — Flutterwave (OB-06x) ───────
# Routes M-Pesa, MTN MoMo, Airtel via Flutterwave's hosted page. Unset = dev
# fallback. Pay-per-period. Webhook URL:
#   {PUBLIC_API_URL}/api/subscriptions/webhook/mobile_money
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
# Currency charged for mobile money (M-Pesa is KES). NOTE: prices are stored in
# USD cents; add an FX step before charging a non-USD currency in production.
MOBILE_MONEY_CURRENCY=KES

# ─── FX / currency conversion (OB-06x) ──────────────────
# Optional live USD-base rates source returning { rates: { EUR: 0.92, … } }.
# Unset = built-in static rate table (dev/fallback). Rates are cached.
FX_API_URL=
FX_CACHE_TTL_MS=3600000

# ─── Email ──────────────────────────────────────────────
# Provider: "mock" (logs; default) or "resend" (real send in prod).
NOTIFIER_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM=Overlay Bets <no-reply@overlay.bet>
# Public API origin used to build one-click unsubscribe links (OB-033).
# Falls back to NEXT_PUBLIC_API_URL, then http://localhost:4000.
PUBLIC_API_URL=http://localhost:4000
# Daily-digest fan-out cadence for daily-cadence subscribers (default 24h).
DIGEST_INTERVAL_MS=86400000
# Weekly "Picks of the Week" newsletter cadence (OB-157, default 7 days). Set
# to 0 to disable the scheduled send (admins can still trigger it manually).
NEWSLETTER_DIGEST_INTERVAL_MS=604800000
# Public web origin used to build newsletter confirm / unsubscribe links
# (OB-157). Falls back to NEXT_PUBLIC_SITE_URL, then http://localhost:3000.
PUBLIC_WEB_URL=http://localhost:3000

# ─── Web Push (VAPID) ───────────────────────────────────
# Generate a key pair once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent to push services (mailto: or https:). Optional.
VAPID_SUBJECT=mailto:no-reply@overlay.bet

# ─── Seed (npm run db:seed) ─────────────────────────────
SEED_ADMIN_EMAIL=admin@overlay.local
SEED_ADMIN_PASSWORD=change-me-now
